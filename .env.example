# ─────────────────────────────────────────────────────────────────────────────
# Anniversary Coin ($ANN) — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Network ──────────────────────────────────────────────────────────────────
# Toggle between devnet (testing) and mainnet-beta (production) here.
# This is the ONLY change needed to switch environments.
SOLANA_NETWORK=devnet

# Optional: override the default cluster RPC endpoint.
# Leave empty to use the public default for the selected network.
# For production, use a dedicated RPC (e.g. QuickNode, Helius, Triton).
# RPC_URL=https://your-private-rpc-endpoint.com

# ── Deployer Wallet ───────────────────────────────────────────────────────────
# The wallet that pays for all transactions and holds Mint Authority.
#
# Two accepted formats:
#   1. Byte array (exported from Solana CLI or Phantom):  [12,34,56,...,255]
#   2. Base58 string (64-byte secret key): 5J...abc
#
DEPLOYER_PRIVATE_KEY=

# ── Distribution Wallets (public keys only — not secrets) ─────────────────────
# These default to the hard-coded values in create-token.ts.
# Override here if you want to target different wallets without touching code.
WALLET_ANNA=DVS3MKunGmucdGowjd7aD2FKebdMwEmbaLb4LSpHj567
WALLET_DEV=4eRS2oRvWJCYdkhnCSroYgBbeep8fVfqSSqhuZG4KsZZ
WALLET_AIRDROP=u9Uv8ZkKV6kYmyZHY2Z1DcFL8hShvnEMPA9FtnqzFkm
WALLET_LP=ECgnGXk2gviaGZHDdvEizXGfu7rsgYQLuCwSyJ98tMV6

# ── Token (populated after running create-token.ts) ───────────────────────────
# Set TOKEN_MINT_ADDRESS from the output of create-token.ts.
# Required by daily-mint.ts.
TOKEN_MINT_ADDRESS=
